<Window x:Class="VirtualKeyboardReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual Keyboard Receiver" Height="330" Width="480"
        Icon="Assets/receiver.ico"
        MinHeight="300" MinWidth="440" WindowStartupLocation="CenterScreen" Background="#10141C">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="Virtual Keyboard Receiver" Foreground="#F3F6FA" FontSize="22" FontWeight="SemiBold"/>
        <Border Grid.Row="1" Margin="0,16,0,14" Padding="12,8" CornerRadius="6" Background="#172A22">
            <StackPanel Orientation="Horizontal"><Ellipse Width="9" Height="9" Fill="#4ADE80" Margin="0,0,9,0"/><TextBlock x:Name="StatusText" Text="Starting…" Foreground="#D9FBE6" FontWeight="SemiBold"/></StackPanel>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="LAN IPv4" Foreground="#93A4B8"/><TextBlock x:Name="AddressText" Grid.Column="1" Foreground="White" TextWrapping="Wrap"/>
            <TextBlock Grid.Row="1" Text="Port" Foreground="#93A4B8"/><TextBlock Grid.Row="1" Grid.Column="1" Text="39421" Foreground="White"/>
            <TextBlock Grid.Row="2" Text="Pairing code" Foreground="#93A4B8"/><TextBlock x:Name="PairingText" Grid.Row="2" Grid.Column="1" Foreground="#7DD3FC" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
            <TextBlock Grid.Row="3" Text="Certificate" Foreground="#93A4B8"/><TextBlock x:Name="FingerprintText" Grid.Row="3" Grid.Column="1" Foreground="#CBD5E1" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
        </Grid>
        <TextBlock Grid.Row="3" Margin="0,14,0,0" Foreground="#718096" Text="Closing hides to the notification area. Use Exit there to stop."/>
    </Grid>
</Window>
