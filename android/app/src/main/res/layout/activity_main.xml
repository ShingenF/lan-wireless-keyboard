<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="4dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/status_need_settings"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/inputModeSelector"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/synchronousModeButton"
                android:layout_width="72dp"
                android:layout_height="44dp"
                android:background="@drawable/direction_button_background"
                android:clickable="true"
                android:focusable="false"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/synchronous_mode"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deferredModeButton"
                android:layout_width="72dp"
                android:layout_height="44dp"
                android:background="@drawable/direction_button_background"
                android:clickable="true"
                android:focusable="false"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/deferred_mode"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="@string/settings"
                android:focusable="false"
                android:padding="10dp"
                android:src="@drawable/ic_settings" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.local.virtualkeyboard.input.RemoteInputEditText
            android:id="@+id/remoteInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:hint="@string/input_hint"
            android:includeFontPadding="false"
            android:imeOptions="flagNoExtractUi"
            android:inputType="textCapSentences|textAutoCorrect"
            android:maxLines="1"
            android:minLines="1"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="4dp"
            android:paddingBottom="6dp"
            android:saveEnabled="false"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/direction_button_background"
            android:contentDescription="@string/send"
            android:focusable="false"
            android:padding="10dp"
            android:src="@drawable/ic_send"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/syncShortcutContainer"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/inputMethodButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/direction_button_background"
                android:contentDescription="@string/input_method_button"
                android:focusable="false"
                android:padding="10dp"
                android:src="@drawable/ic_globe" />

            <TextView
                android:id="@+id/languageToggleButton"
                android:layout_width="52dp"
                android:layout_height="44dp"
                android:background="@drawable/direction_button_background"
                android:clickable="true"
                android:contentDescription="@string/language_toggle_button"
                android:focusable="false"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/language_toggle_button_label"
                android:textColor="@color/icon_default"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3">

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <ImageButton
                android:id="@+id/upButton"
                style="@style/CompactDirectionButton"
                android:contentDescription="@string/direction_up"
                android:src="@drawable/ic_arrow_up" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <ImageButton
                android:id="@+id/leftButton"
                style="@style/CompactDirectionButton"
                android:contentDescription="@string/direction_left"
                android:src="@drawable/ic_arrow_left" />

            <com.local.virtualkeyboard.ui.JoystickView
                android:id="@+id/joystick"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/joystick" />

            <ImageButton
                android:id="@+id/rightButton"
                style="@style/CompactDirectionButton"
                android:contentDescription="@string/direction_right"
                android:src="@drawable/ic_arrow_right" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <ImageButton
                android:id="@+id/downButton"
                style="@style/CompactDirectionButton"
                android:contentDescription="@string/direction_down"
                android:src="@drawable/ic_arrow_down" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />
        </GridLayout>

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3">

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <TextView
                android:id="@+id/gameUpButton"
                style="@style/CompactGameKeyButton"
                android:contentDescription="@string/game_move_up"
                android:text="@string/game_key_w" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <TextView
                android:id="@+id/gameLeftButton"
                style="@style/CompactGameKeyButton"
                android:contentDescription="@string/game_move_left"
                android:text="@string/game_key_a" />

            <com.local.virtualkeyboard.ui.JoystickView
                android:id="@+id/gameJoystick"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/game_joystick" />

            <TextView
                android:id="@+id/gameRightButton"
                style="@style/CompactGameKeyButton"
                android:contentDescription="@string/game_move_right"
                android:text="@string/game_key_d" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />

            <TextView
                android:id="@+id/gameDownButton"
                style="@style/CompactGameKeyButton"
                android:contentDescription="@string/game_move_down"
                android:text="@string/game_key_s" />

            <Space android:layout_width="48dp" android:layout_height="48dp" />
        </GridLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:minHeight="160dp">

        <com.local.virtualkeyboard.ui.TouchpadView
            android:id="@+id/touchpad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/touchpad_background" />

        <TextView
            android:id="@+id/touchpadHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginTop="52dp"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:layout_marginEnd="56dp"
            android:text="@string/touchpad_gestures"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/escapeButton"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/control_button_background"
            android:clickable="true"
            android:contentDescription="@string/escape_key_description"
            android:focusable="false"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/escape_key"
            android:textColor="@color/icon_default"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rightClickButton"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/control_button_background"
            android:clickable="true"
            android:contentDescription="@string/right_mouse_button_description"
            android:focusable="false"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/right_mouse_button"
            android:textColor="@color/icon_default"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.local.virtualkeyboard.ui.ScrollStripView
            android:id="@+id/scrollStrip"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginTop="58dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />
    </FrameLayout>
</LinearLayout>
