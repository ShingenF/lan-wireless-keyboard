<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BaseAppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/text_primary</item>
        <item name="android:navigationBarColor">@color/screen_background</item>
        <item name="android:statusBarColor">@color/screen_background</item>
        <item name="android:windowBackground">@color/screen_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="AppTheme" parent="@style/BaseAppTheme" />

    <style name="DirectionButton" parent="android:style/Widget.Material.ImageButton">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/direction_button_background</item>
        <item name="android:focusable">false</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="CompactDirectionButton" parent="DirectionButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:padding">9dp</item>
    </style>

    <style name="CompactGameKeyButton" parent="android:style/Widget.Material.TextView">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/direction_button_background</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">false</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/icon_default</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
